{
  "name": "educa-react",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently \"npm --prefix client run dev\" \"npm --prefix server run dev\"",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "build": "npm --prefix client run build",
    "lint": "npm --prefix client run lint && npm --prefix server run lint",
    "prisma:generate": "npm --prefix server run prisma:generate",
    "prisma:migrate": "npm --prefix server run prisma:migrate",
    "prisma:studio": "npm --prefix server run prisma:studio"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
